{
  "name": "tabla-elementos",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Tabla periódica ampliada y estática para explorar elementos, espectros, niveles, propiedades y datos científicos.",
  "scripts": {
    "dev": "npm run build:data && vite --host 0.0.0.0",
    "build:data": "python scripts/build_data.py && python scripts/build_element_data.py",
    "init:elements": "python scripts/init_elements_structure.py",
    "import:nist": "python scripts/import_nist_exports.py --move --overwrite",
    "import:nist:dry": "python scripts/import_nist_exports.py --dry-run",
    "build": "npm run build:data && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "d3": "^7.9.0",
    "svelte": "^5.19.0",
    "vite": "^6.1.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^22.13.1",
    "svelte-check": "^4.1.4",
    "typescript": "^5.7.3"
  }
}
