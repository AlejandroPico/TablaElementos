{
  "name": "espectros-atomicos",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Aplicación científica estática para explorar líneas de emisión y absorción de espectros atómicos.",
  "scripts": {
    "dev": "npm run build:data && vite --host 0.0.0.0",
    "build:data": "python scripts/build_data.py",
    "build": "npm run build:data && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "d3": "^7.9.0",
    "svelte": "^5.19.0",
    "vite": "^6.1.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^22.13.1",
    "svelte-check": "^4.1.4",
    "typescript": "^5.7.3"
  }
}
